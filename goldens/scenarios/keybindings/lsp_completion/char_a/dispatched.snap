FsListDir	path=<TMPDIR>
FileOpen	path=<TMPDIR>/main.rs create_if_missing=true
LspSend	server=fake-lsp kind=request method=initialize id=1
LspRecv	server=fake-lsp kind=response id=1
LspSend	server=fake-lsp kind=notification method=initialized
LspSend	server=fake-lsp kind=notification method=workspace/didChangeConfiguration
LspSend	server=fake-lsp kind=notification method=textDocument/didOpen path=file://<TMPDIR>/main.rs version=1
LspRecv	server=fake-lsp kind=notification method=$/progress
LspRecv	server=fake-lsp kind=notification method=$/progress
GitScan	root=<TMPDIR>
WorkspaceFlushUndo	path=<TMPDIR>/main.rs chain=<CHAIN>
WorkspaceCheckSync	path=<TMPDIR>/main.rs
LspSend	server=fake-lsp kind=notification method=textDocument/didChange path=file://<TMPDIR>/main.rs version=2
LspSend	server=fake-lsp kind=request method=textDocument/completion id=2 path=file://<TMPDIR>/main.rs
LspRecv	server=fake-lsp kind=response id=2
