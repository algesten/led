FsListDir	path=<TMPDIR>
FileOpen	path=<TMPDIR>/a.txt create_if_missing=true
FileSearch	query="n" root=<TMPDIR> case=false regex=false
FileSearch	query="ne" root=<TMPDIR> case=false regex=false
FileSearch	query="nee" root=<TMPDIR> case=false regex=false
FileSearch	query="need" root=<TMPDIR> case=false regex=false
FileSearch	query="needl" root=<TMPDIR> case=false regex=false
FileSearch	query="needle" root=<TMPDIR> case=false regex=false
FileSearchReplace	query="needle" replacement="pin" root=<TMPDIR> case=false regex=false
